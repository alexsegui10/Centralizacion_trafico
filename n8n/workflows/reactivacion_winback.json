    "Fetch Winback Flow 3": { "main": [[{ "node": "Array to Items Social", "type": "main", "index": 0 }]] },
    "Array to Items Social": { "main": [[{ "node": "Send Winback Flow 3", "type": "main", "index": 0 }]] },
    "Send Winback Flow 3": { "main": [[{ "node": "Mark Winback Flow 3", "type": "main", "index": 0 }]] },
    "Fetch Winback Flow 5": { "main": [[{ "node": "Array to Items MGO", "type": "main", "index": 0 }]] },
    "Array to Items MGO": { "main": [[{ "node": "Send Winback Flow 5", "type": "main", "index": 0 }]] },
    "Send Winback Flow 5": { "main": [[{ "node": "Mark Winback Flow 5", "type": "main", "index": 0 }]] }
  },
