SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=-1000000000000

N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=change_this_to_a_long_random_string
GENERIC_TIMEZONE=UTC

WEBHOOK_URL=https://your-whatsapp-provider-webhook

# Daily health check
ALERT_WEBHOOK_URL=http://your-vps-ip:8088/webhook/alerta

# Daily Supabase backup
SUPABASE_BACKUP_TABLES=leads,eventos
SUPABASE_BACKUP_DIR=backups/supabase
SUPABASE_BACKUP_PAGE_SIZE=1000
SUPABASE_BACKUP_KEEP_DAYS=14