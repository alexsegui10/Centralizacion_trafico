{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://krnabtkugfzfinwvfuzm.supabase.co/functions/v1/api-:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-timestamp, x-signature" }
      ]
    }
  ]
}
